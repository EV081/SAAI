# ---- Serverless Framework ----
# Nombre de tu organización en Serverless Dashboard (app.serverless.com)
SERVERLESS_ORG=tu-org-aqui

# ---- AWS ----
# ID de cuenta AWS (visible en la consola de AWS Academy)
AWS_ACCOUNT_ID=YOUR_ACCOUNT_ID_HERE

# ---- Seguridad JWT ----
# Clave secreta para firmar tokens JWT (usar valor largo y aleatorio en prod)
JWT_SECRET=change-me-in-production
